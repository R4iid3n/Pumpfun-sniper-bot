{
  "_name": "config3 — early entry + realistic filters",
  "_date": "2026-02-23",
  "_notes": [
    "Entry: gain ≥2%, age ≥1.5s, vol ≥0.25 SOL",
    "Normal lane (3+ buys): no wallet requirement — momentum+volume filters handle quality",
    "Fast lane (2 buys): requires 2+ wallets AND momentum ≥ 0.7",
    "Wallet filter removed from normal lane — pump.fun tokens start with 1 dev wallet,",
    "  organic multi-wallet buying rarely happens in the 15s entry window",
    "max_single_buy_sol: 0.50 (blocks whale bait pumps)",
    "Momentum scoring: 3-signal weighted, works with 2+ buy events"
  ],

  "maxPositionSize": 0.05,
  "trailingStop": 5,
  "trailingTakeProfit": 15,
  "momentumStaleSeconds": 7,
  "latencySlippagePct": 2,
  "minLiquidity": 3,
  "maxDevHolding": 12,
  "maxTopHolder": 25,
  "minBurnerHolderPct": 8.0,
  "burnerTxThreshold": 5,
  "minBurnersToBlock": 3,
  "autoTrade": true,
  "maxOpenPositions": 1,
  "useMartingale": false,
  "useSoftMartingale": false,
  "martingaleMultiplier": 2.0,
  "maxMartingaleLevel": 3,
  "earlyDumpDetection": true,
  "earlyDumpThreshold": -7,
  "earlyDumpWindow": 15,
  "noBuysExit": true,
  "noBuysWindow": 3,
  "useTwitterSentiment": false,

  "_entry_filters": {
    "price_gain_min_pct": 2,
    "price_gain_max_pct": 7,
    "min_buy_count_normal": 3,
    "min_buy_count_fast_lane": "2 (requires 2 wallets + momentum ≥ 0.7)",
    "min_sol_volume": 0.25,
    "avg_buy_sol_min": 0.07,
    "avg_buy_sol_max": 0.50,
    "max_single_buy_sol": 0.50,
    "max_sell_drop_pct": 1.5,
    "min_unique_buyers_normal": "none (3+ buys is enough confirmation)",
    "min_unique_buyers_fast_lane": 2,
    "momentum_threshold_normal": 0.4,
    "momentum_threshold_fast_lane": 0.7,
    "min_age_s": 1.5,
    "max_age_s": 15
  }
}
